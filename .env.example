# Copy this file to .env and edit the values for your machine.
# .env is gitignored — never commit it.

# ─── Data location ────────────────────────────────────────────────────────────
# Absolute path to the directory holding the raw Kaggle CSVs:
#   application_train.csv, application_test.csv, bureau.csv, bureau_balance.csv,
#   previous_application.csv, installments_payments.csv, POS_CASH_balance.csv,
#   credit_card_balance.csv, HomeCredit_columns_description.csv, sample_submission.csv
#
# On Aly's machine: G:/home-credit-default-risk
# Default if unset: ./data/raw
DATA_DIR=G:/home-credit-default-risk

# ─── Optional overrides ───────────────────────────────────────────────────────
# Override the project workspace root (default: repository root).
# PROJECT_ROOT=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Random seed (used by utils.set_seed)
SEED=42

# Number of CV folds (main StratifiedKFold)
N_FOLDS=5

# GPU / device hints (forwarded to LGBM/XGB/CatBoost/torch where applicable)
USE_GPU=1
