# ─── Project: data is huge, never commit ──────────────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/features/*
!data/features/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ─── Project: artifacts are reproducible, do not commit ───────────────────────
artifacts/models/*
!artifacts/models/.gitkeep
artifacts/predictions/*
!artifacts/predictions/.gitkeep
artifacts/*.csv
artifacts/*.log

# ─── Project: submissions log kept, files ignored ─────────────────────────────
submissions/*.csv
!submissions/log.csv
!submissions/.gitkeep

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml
*.cover
